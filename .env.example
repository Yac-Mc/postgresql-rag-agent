# Postgres (local, vía Docker: contenedor "postgres-local")
# El nombre de la base de datos final va incluido en esta URL.
# Si la base de datos indicada no existe, el bootstrap la crea automáticamente.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_demo

# Nombre de la tabla de demo que siembra el bootstrap (opcional)
APP_DB_TABLE=registros

# Esquema de Postgres a introspeccionar (opcional, default: public)
APP_DB_SCHEMA=public

# Neo4j (local, vía Docker: contenedor "neo4j-local")
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Gemini (Google AI Studio) - usado vía langchain-google-genai
GEMINI_API_KEY=
